# Database Configuration
# Set to 'true' to use Supabase, 'false' or leave empty to use SQLite
USE_SUPABASE=true

# SQLite Configuration (only used if USE_SUPABASE is false)
DATABASE_PATH=./database/hackuni.db

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Direct database connection (for migrations)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Application Configuration
JWT_SECRET=your-secret-key-here-change-in-production
EMAIL_VERIFICATION_SECRET=your-email-verification-secret-here
NODE_ENV=development

# Custom email delivery for registration verification
RESEND_API_KEY=
EMAIL_FROM="AttraX <noreply@attrax.world>"
EMAIL_REPLY_TO=

# Vercel Configuration (for production)
# These will be automatically set when deploying to Vercel
VERCEL_URL=
VERCEL_ENV=
