# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# md (ignore all but README.md and config guides)
*.md
!README.md
!PRODUCTION_SETUP.md
!SUPABASE_SYNC.md
!QUICK_SETUP.md
!MIGRATION_GUIDE.md

# claude skills (local only)
.claude/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite temporary files
*.db-shm
*.db-wal
database/*.db-shm
database/*.db-wal

# Supabase local temp artifacts
supabase/.temp/
